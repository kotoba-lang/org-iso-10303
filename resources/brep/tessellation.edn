;; EDN authority for kami-cad's tessellation LOD constants and epsilon
;; thresholds (previously hardcoded magic numbers scattered through the
;; Rust `tessellate` / `brep` modules). Kept in sync with the inline
;; mirror in `brep.config` — see `brep-test/edn-matches-resource`.
{:cylinder {:segments 24
            :default-height 1.0}
 :sphere {:u-segments 16
          :v-segments 12}
 :epsilon {:point-merge 1e-12
           :knot-denominator 1e-14}}
